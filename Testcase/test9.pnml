<pnml xmlns="http://www.pnml.org/version-2009/grammar/pnml">
 <net id="test9" type="http://www.pnml.org/version-2009/grammar/ptnet">
  <page id="page1">
   <place id="p1"><name><text>Start</text></name><initialMarking><text>1</text></initialMarking></place>
   
   <place id="p2"><name><text>DeadEnd</text></name></place>
   <transition id="t1"><name><text>GoDie</text></name></transition>
   <arc id="a1" source="p1" target="t1"/>
   <arc id="a2" source="t1" target="p2"/>

   <place id="p3"><name><text>LoopA</text></name></place>
   <place id="p4"><name><text>LoopB</text></name></place>
   
   <transition id="t2"><name><text>GoLive</text></name></transition>
   <transition id="t3"><name><text>Cycle1</text></name></transition>
   <transition id="t4"><name><text>Cycle2</text></name></transition>

   <arc id="a3" source="p1" target="t2"/>
   <arc id="a4" source="t2" target="p3"/>
   <arc id="a5" source="p3" target="t3"/>
   <arc id="a6" source="t3" target="p4"/>
   <arc id="a7" source="p4" target="t4"/>
   <arc id="a8" source="t4" target="p3"/>
  </page>
 </net>
</pnml>